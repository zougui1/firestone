{
  "name": "@zougui/firestone.bot",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.mjs",
  "scripts": {
    "build": "tsdown src/index.ts",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsup src/index.ts",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint",
    "start": "pnpm with-env node dist/index.mjs",
    "typecheck": "tsc --noEmit",
    "with-env": "dotenv -e ../../.env -e .env --"
  },
  "dependencies": {
    "@xstate/store": "^3.15.0",
    "@zougui/firestone.db": "workspace:^",
    "@zougui/firestone.war-machines": "workspace:^",
    "axios": "^1.13.4",
    "big.js": "^7.0.1",
    "commander": "^14.0.3",
    "effect": "^3.19.16",
    "emittery": "^1.2.0",
    "env-var": "^7.5.0",
    "execa": "^9.6.1",
    "fast-levenshtein": "^3.0.0",
    "immer": "^11.1.3",
    "nanoid": "^2.1.11",
    "node-moving-things-tracker": "^0.9.1",
    "radash": "^12.1.1",
    "tsdown": "^0.20.3",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@types/ws": "^8.18.1",
    "@zougui/firestone.types": "workspace:^",
    "dotenv-cli": "^8.0.0",
    "eslint": "^10.0.0",
    "jiti": "^2.4.2",
    "tsup": "^8.5.1",
    "typescript": "catalog:"
  },
  "prettier": "@zougui/prettier-config"
}
